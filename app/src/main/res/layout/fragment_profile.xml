<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="👤 Profil"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp" />

        <CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/username_text"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Kullanıcı Adı"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/premium_status_text"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Ücretsiz Üye"
                    android:textSize="14sp"
                    android:textColor="#666"
                    android:layout_marginBottom="16dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Senin Burçun:"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/zodiac_text"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Seçiniz"
                    android:textSize="12sp"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/zodiac_detail_text"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Detaylar"
                    android:textSize="11sp"
                    android:layout_marginBottom="16dp" />

                <TextView
                    android:id="@+id/numerology_text"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Numeroloji Bilgisi"
                    android:textSize="11sp"
                    android:layout_marginBottom="16dp" />

                <Button
                    android:id="@+id/edit_profile_button"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Profili Düzenle"
                    android:layout_marginBottom="8dp" />

                <Button
                    android:id="@+id/buy_premium_button"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Premium Satın Al 🌟"
                    android:layout_marginBottom="8dp" />

                <Button
                    android:id="@+id/logout_button"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Çıkış Yap"
                    android:textColor="#FF0000" />

            </LinearLayout>

        </CardView>

        <com.google.android.gms.ads.AdView
            android:id="@+id/adView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="20dp"
            app:adSize="BANNER"
            app:adUnitId="ca-app-pub-3940256099942544/6300978111" />

    </LinearLayout>

</ScrollView>